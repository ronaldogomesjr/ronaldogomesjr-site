diff --git a/assets/style.css b/assets/style.css
--- a/assets/style.css
+++ b/assets/style.css
@@
+/*
+ * Evita a exibição momentânea do conteúdo estático antigo enquanto
+ * content/pages.json é carregado por assets/page-content.js.
+ */
+html.page-content-loading [data-page-shell] {
+  visibility: hidden;
+}
+

diff --git a/assets/page-content.js b/assets/page-content.js
--- a/assets/page-content.js
+++ b/assets/page-content.js
@@
   document.addEventListener('DOMContentLoaded', async function () {
     const shell = document.querySelector('[data-page-shell]');
-    if (!shell) return;
+    if (!shell) {
+      document.documentElement.classList.remove('page-content-loading');
+      return;
+    }
     const slug = shell.getAttribute('data-page-slug');
     const lang = shell.getAttribute('data-lang') || 'pt';
@@
     } catch (error) {
       console.error('Erro ao carregar páginas:', error);
+    } finally {
+      if (window.__pageContentFallback) {
+        window.clearTimeout(window.__pageContentFallback);
+      }
+      document.documentElement.classList.remove('page-content-loading');
     }
   });
 })();

diff --git a/pt/sobre/index.html b/pt/sobre/index.html
--- a/pt/sobre/index.html
+++ b/pt/sobre/index.html
@@
   <link rel="stylesheet" href="/assets/style.css" />
+  <script>
    document.documentElement.classList.add('page-content-loading');
    window.__pageContentFallback = window.setTimeout(function () {
      document.documentElement.classList.remove('page-content-loading');
    }, 4000);
  </script>
 </head>

