{
  "cleanUrls": true,
  "trailingSlash": true,
  "installCommand": "npm install --no-audit --no-fund",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/pt/pesquisa",
      "destination": "/pt/projetos/",
      "permanent": true
    },
    {
      "source": "/pt/pesquisa/",
      "destination": "/pt/projetos/",
      "permanent": true
    },
    {
      "source": "/en/research",
      "destination": "/en/projects/",
      "permanent": true
    },
    {
      "source": "/en/research/",
      "destination": "/en/projects/",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/pt/",
      "permanent": false
    }
  ]
}
