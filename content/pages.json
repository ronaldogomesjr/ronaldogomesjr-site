    {
      "id": "sobre",
      "slug_pt": "sobre",
      "slug_en": "about",
      "title_pt": "sobre",
      "title_en": "about",
      "intro_pt": "Ronaldo Gomes Jr. é professor, pesquisador e curioso por tudo o que envolve linguagem, tecnologia e educação. Atua na Universidade Federal de Minas Gerais, onde desenvolve pesquisas na interface entre educação linguística, tecnologias digitais, design e inteligência artificial. É também autor de livros didáticos de inglês para os ensinos Fundamental e Médio.",
      "intro_en": "Ronaldo Gomes Jr. is a professor, researcher and curious thinker interested in everything that connects language, technology and education. He works at the Federal University of Minas Gerais, where he conducts research at the intersection of language education, digital technologies, design and artificial intelligence. He is also the author of English language textbooks for primary and secondary education.",
      "meta_title_pt": "",
      "meta_title_en": "",
      "meta_description_pt": "",
      "meta_description_en": "",
      "ordem": 5,
      "section1_title_pt": "Trajetória",
      "section1_title_en": "Trajectory",
      "section1_text_pt": "Graduado em Letras pela UFV, mestre e doutor em Estudos Linguísticos pela UFMG e especialista em Design Digital pelo Instituto Infnet, realizou pós-doutorados na Macquarie University, na Austrália, e na PUC Minas. Sua trajetória reúne ensino, pesquisa, extensão, produção editorial, formação de professores e desenvolvimento de projetos educacionais.",
      "section1_text_en": "He holds a degree in Languages from UFV, a master’s and a PhD in Linguistic Studies from UFMG, and a specialization in Digital Design from Instituto Infnet. He completed postdoctoral research at Macquarie University, in Australia, and at PUC Minas. His trajectory brings together teaching, research, outreach, editorial work, teacher education and the development of educational projects.",
      "section1_link_label_pt": "",
      "section1_link_label_en": "",
      "section1_link_url_pt": "",
      "section1_link_url_en": "",
      "section2_title_pt": "Interesses",
      "section2_title_en": "Interests",
      "section2_text_pt": "Seus interesses de pesquisa incluem educação linguística, tecnologias digitais, inteligência artificial, design da aprendizagem, recursos educacionais abertos, letramento crítico, formação docente e práticas pedagógicas mais abertas, colaborativas e socialmente responsáveis.",
      "section2_text_en": "His research interests include language education, digital technologies, artificial intelligence, learning design, open educational resources, critical literacy, teacher education and more open, collaborative and socially responsible pedagogical practices.",
      "section2_link_label_pt": "",
      "section2_link_label_en": "",
      "section2_link_url_pt": "",
